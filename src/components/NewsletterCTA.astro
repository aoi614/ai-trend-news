---
/**
 * NewsletterCTA - メルマガ登録フォーム
 * 記事末尾やフッター付近に配置するニュースレター登録CTA
 */
---

<div class="newsletter-cta">
	<div class="newsletter-inner">
		<div class="newsletter-icon">📬</div>
		<h3 class="newsletter-title">最新AI情報を<span class="highlight">メールで受け取る</span></h3>
		<p class="newsletter-desc">毎週の注目ニュースをまとめてお届け。登録は無料です。</p>
		<form class="newsletter-form" id="newsletter-form">
			<input
				type="email"
				name="email"
				placeholder="your@email.com"
				required
				class="newsletter-input"
				id="newsletter-email"
			/>
			<button type="submit" class="newsletter-btn" id="newsletter-submit">
				購読する
			</button>
		</form>
		<p class="newsletter-note">🔒 スパムは送りません。いつでも解除可能です。</p>
	</div>
</div>

<script>
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('newsletter-form');
		const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
		const submitBtn = document.getElementById('newsletter-submit');
		if (form && emailInput && submitBtn) {
			form.addEventListener('submit', (e) => {
				e.preventDefault();
				const email = emailInput.value;
				if (!email) return;

				// Store subscriber locally (can be replaced with API call)
				const subs = JSON.parse(localStorage.getItem('newsletter-subs') || '[]');
				if (!subs.includes(email)) {
					subs.push(email);
					localStorage.setItem('newsletter-subs', JSON.stringify(subs));
				}

				submitBtn.textContent = '✅ 登録完了！';
				submitBtn.setAttribute('disabled', 'true');
				emailInput.value = '';
				emailInput.setAttribute('disabled', 'true');

				setTimeout(() => {
					submitBtn.textContent = '購読する';
					submitBtn.removeAttribute('disabled');
					emailInput.removeAttribute('disabled');
				}, 3000);
			});
		}
	});
</script>

<style>
	.newsletter-cta {
		max-width: 760px;
		margin: 0 auto;
		padding: 0 1.5rem 2rem;
	}
	.newsletter-inner {
		text-align: center;
		padding: 2.5rem 2rem;
		background: linear-gradient(135deg, rgba(14,165,233,0.08) 0%, rgba(56,189,248,0.05) 100%);
		border: 1px solid rgba(14,165,233,0.15);
		border-radius: 16px;
		position: relative;
		overflow: hidden;
	}
	.newsletter-inner::before {
		content: '';
		position: absolute;
		top: -50%;
		right: -30%;
		width: 200px;
		height: 200px;
		background: radial-gradient(circle, rgba(14,165,233,0.1) 0%, transparent 70%);
		border-radius: 50%;
		pointer-events: none;
	}
	.newsletter-icon {
		font-size: 2.5rem;
		margin-bottom: 0.75rem;
	}
	.newsletter-title {
		font-size: 1.3rem;
		font-weight: 700;
		color: rgb(var(--gray-dark));
		margin-bottom: 0.5rem;
	}
	.highlight {
		background: linear-gradient(135deg, #0ea5e9, #38bdf8);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.newsletter-desc {
		font-size: 0.88rem;
		color: rgb(var(--gray));
		margin-bottom: 1.5rem;
		line-height: 1.5;
	}
	.newsletter-form {
		display: flex;
		gap: 0.5rem;
		max-width: 420px;
		margin: 0 auto 0.75rem;
	}
	.newsletter-input {
		flex: 1;
		padding: 0.7rem 1rem;
		border: 1px solid rgba(var(--gray-light), 0.8);
		border-radius: 10px;
		background: var(--card-bg, white);
		color: rgb(var(--gray-dark));
		font-size: 0.9rem;
		outline: none;
		transition: border-color 0.2s;
	}
	.newsletter-input:focus {
		border-color: #0ea5e9;
		box-shadow: 0 0 0 3px rgba(14,165,233,0.15);
	}
	.newsletter-btn {
		padding: 0.7rem 1.5rem;
		background: linear-gradient(135deg, #0ea5e9, #0284c7);
		color: white;
		font-weight: 600;
		font-size: 0.9rem;
		border: none;
		border-radius: 10px;
		cursor: pointer;
		transition: all 0.2s;
		white-space: nowrap;
	}
	.newsletter-btn:hover {
		transform: translateY(-1px);
		box-shadow: 0 4px 14px rgba(14,165,233,0.4);
	}
	.newsletter-btn:disabled {
		opacity: 0.7;
		cursor: not-allowed;
		transform: none;
	}
	.newsletter-note {
		font-size: 0.72rem;
		color: rgb(var(--gray));
		opacity: 0.7;
	}
	@media (max-width: 480px) {
		.newsletter-form {
			flex-direction: column;
		}
	}
</style>
