---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	pubDate?: Date;
	updatedDate?: Date;
	type?: 'website' | 'article';
	breadcrumbs?: { name: string; url: string }[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	pubDate,
	updatedDate,
	type = 'website',
	breadcrumbs,
} = Astro.props;

// Build structured data
const structuredData: Record<string, any> = {
	"@context": "https://schema.org",
	"@type": type === 'article' ? "BlogPosting" : "WebSite",
	"headline": title,
	"description": description,
	"image": new URL(typeof image === 'string' ? image : image.src, Astro.url).toString(),
	"url": canonicalURL.toString(),
	"author": {
		"@type": "Organization",
		"name": "AIトレンド速報",
		"url": Astro.site?.toString() || "https://ai-trend-news.com"
	},
	"publisher": {
		"@type": "Organization",
		"name": "AIトレンド速報",
		"url": Astro.site?.toString() || "https://ai-trend-news.com",
		"logo": {
			"@type": "ImageObject",
			"url": new URL("/favicon.svg", Astro.site || "https://ai-trend-news.com").toString()
		}
	}
};

if (pubDate) {
	structuredData.datePublished = pubDate.toISOString();
}
if (updatedDate) {
	structuredData.dateModified = updatedDate.toISOString();
} else if (pubDate) {
	structuredData.dateModified = pubDate.toISOString();
}

// Breadcrumb structured data
const breadcrumbData = breadcrumbs ? {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbs.map((item, index) => ({
		"@type": "ListItem",
		"position": index + 1,
		"name": item.name,
		"item": new URL(item.url, Astro.site || "https://ai-trend-news.com").toString()
	}))
} : null;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<ClientRouter fallback="swap" />

<!-- PWA / Web App Settings -->
<link rel="manifest" href="/manifest.json" />
<meta name="theme-color" content="#0f172a" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />

<!-- Performance: Preconnect & DNS Prefetch -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
<link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />

<!-- Google Fonts: Non-blocking async load with font-display:swap -->
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" />
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
<noscript><link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" /></noscript>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(typeof image === 'string' ? image : image.src, Astro.url)} />
<meta property="og:site_name" content="AIトレンド速報" />
<meta property="og:locale" content="ja_JP" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(typeof image === 'string' ? image : image.src, Astro.url)} />

<!-- Article-specific meta -->
{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
{updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}

<!-- SEO JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

<!-- Breadcrumb JSON-LD -->
{breadcrumbData && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbData)} />}

<!-- Google tag (gtag.js) - deferred for performance -->
<script is:inline>
window.addEventListener('load', function() {
  var s = document.createElement('script');
  s.src = 'https://www.googletagmanager.com/gtag/js?id=G-L0YV5M9E9L';
  s.async = true;
  document.head.appendChild(s);
  s.onload = function() {
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-L0YV5M9E9L');
  };
});
</script>

<!-- Google AdSense - deferred loading for Core Web Vitals -->
<meta name="google-adsense-account" content="ca-pub-8204767432830277">
<script is:inline>
window.addEventListener('load', function() {
  setTimeout(function() {
    var s = document.createElement('script');
    s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8204767432830277';
    s.async = true;
    s.crossOrigin = 'anonymous';
    document.head.appendChild(s);
  }, 2000);
});
</script>

<!-- Initialize Theme -->
<script is:inline>
	const setDarkMode = () => {
		const theme = (() => {
			if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
				return localStorage.getItem('theme');
			}
			return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
		})();
		const isDark = theme === 'dark';
		document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
		document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
	};
	setDarkMode();
	document.addEventListener('astro:after-swap', setDarkMode);
</script>

<!-- PWA Service Worker + Push Notification -->
<script is:inline>
	if ('serviceWorker' in navigator) {
		window.addEventListener('load', async () => {
			try {
				const registration = await navigator.serviceWorker.register('/sw.js');
				
				// 通知許可をまだ求めていない場合、バナーを表示
				if ('Notification' in window && Notification.permission === 'default') {
					// 2回目以降の訪問（またはスクロール後）にバナー表示
					const visited = localStorage.getItem('ai-trend-visited');
					if (visited) {
						setTimeout(() => showNotificationBanner(registration), 8000);
					} else {
						localStorage.setItem('ai-trend-visited', 'true');
					}
				}

				// 通知が許可済みの場合: 新記事チェック
				if ('Notification' in window && Notification.permission === 'granted') {
					checkForNewArticles(registration);
				}
			} catch (error) {
				console.error('ServiceWorker registration failed: ', error);
			}
		});
	}

	function showNotificationBanner(registration) {
		// 既にバナーが表示されている場合はスキップ
		if (document.getElementById('push-banner')) return;

		const banner = document.createElement('div');
		banner.id = 'push-banner';
		banner.innerHTML = `
			<div style="
				position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
				z-index:9999;max-width:460px;width:calc(100% - 32px);
				background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);
				border:1px solid rgba(14,165,233,0.3);border-radius:16px;
				padding:20px 24px;display:flex;align-items:center;gap:16px;
				box-shadow:0 8px 32px rgba(0,0,0,0.4);
				animation:slideUp 0.4s cubic-bezier(0.22,1,0.36,1);
			">
				<div style="font-size:2rem;flex-shrink:0;">🔔</div>
				<div style="flex:1;">
					<div style="color:#f1f5f9;font-weight:700;font-size:0.95rem;margin-bottom:4px;">最新AI記事を通知で受け取る</div>
					<div style="color:#94a3b8;font-size:0.8rem;">新着記事が公開されたらお知らせします</div>
				</div>
				<div style="display:flex;gap:8px;flex-shrink:0;">
					<button id="push-allow" style="
						background:linear-gradient(135deg,#0ea5e9,#38bdf8);color:#fff;
						border:none;border-radius:10px;padding:8px 16px;font-size:0.85rem;
						font-weight:600;cursor:pointer;
					">許可する</button>
					<button id="push-dismiss" style="
						background:transparent;color:#64748b;border:1px solid #334155;
						border-radius:10px;padding:8px 12px;font-size:0.8rem;cursor:pointer;
					">✕</button>
				</div>
			</div>
		`;
		document.body.appendChild(banner);

		// アニメーション
		const style = document.createElement('style');
		style.textContent = '@keyframes slideUp{from{opacity:0;transform:translateX(-50%) translateY(20px);}to{opacity:1;transform:translateX(-50%) translateY(0);}}';
		document.head.appendChild(style);

		document.getElementById('push-allow').addEventListener('click', async () => {
			const result = await Notification.requestPermission();
			banner.remove();
			if (result === 'granted') {
				checkForNewArticles(registration);
			}
		});

		document.getElementById('push-dismiss').addEventListener('click', () => {
			banner.remove();
			localStorage.setItem('push-dismissed', Date.now().toString());
		});
	}

	async function checkForNewArticles(registration) {
		try {
			const lastCheck = localStorage.getItem('last-article-check') || '2000-01-01';
			const res = await fetch('/rss.xml');
			const text = await res.text();
			const parser = new DOMParser();
			const xml = parser.parseFromString(text, 'text/xml');
			const items = xml.querySelectorAll('item');
			
			if (items.length > 0) {
				const firstItem = items[0];
				const pubDate = firstItem.querySelector('pubDate')?.textContent || '';
				const title = firstItem.querySelector('title')?.textContent || '';
				const link = firstItem.querySelector('link')?.textContent || '/';
				
				if (pubDate && new Date(pubDate) > new Date(lastCheck)) {
					// 新しい記事が見つかった！Service Workerに通知を依頼
					if (registration.active) {
						registration.active.postMessage({
							type: 'NEW_ARTICLE',
							title: title,
							url: link,
						});
					}
				}
			}
			
			localStorage.setItem('last-article-check', new Date().toISOString());
		} catch (e) {
			console.log('Article check skipped:', e.message);
		}
	}
</script>
